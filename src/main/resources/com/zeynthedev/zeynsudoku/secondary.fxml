<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox  alignment="CENTER" spacing="30.0" prefWidth="720.0" prefHeight="620.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.zeynthedev.zeynsudoku.SecondaryController">
    <children>
        <Label text="ZeynSUDOKU">
            <font>
                <Font name="System Bold" size="36.0" /> 
            </font>
        </Label>
        
        <VBox alignment="CENTER" spacing="15.0">
            <Button fx:id="btnContinue" text="Continue" onAction="#actContinue" prefWidth="200" prefHeight="40" />
            <Button text="Start New Game" onAction="#actNewGame" prefWidth="200" prefHeight="40" />
            <Button text="Exit" onAction="#actExit" prefWidth="200" prefHeight="40" /> 
        </VBox>  
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
